<!DOCTYPE html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Send SMS</title>
    <style>
      body {
        font-family: sans-serif;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        margin: 0;
        background: #f5f5f5;
      }
      .card {
        background: white;
        border-radius: 10px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);
        padding: 2rem;
        width: 320px;
      }
      .header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
      }
      h1 {
        margin: 0;
        font-size: 1.3rem;
        color: #333;
      }
      .status {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.8rem;
        color: #666;
      }
      .dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: #ccc;
        transition: background 0.3s;
      }
      .dot.connected {
        background: #22c55e;
        box-shadow: 0 0 6px #22c55e;
      }
      input {
        width: 100%;
        padding: 0.6rem 0.75rem;
        margin-bottom: 1rem;
        border: 1px solid #ddd;
        border-radius: 6px;
        font-size: 1rem;
        box-sizing: border-box;
      }
      button {
        width: 100%;
        padding: 0.75rem;
        background: #0070f3;
        color: white;
        border: none;
        border-radius: 6px;
        font-size: 1rem;
        cursor: pointer;
        transition: background 0.2s;
      }
      button:hover { background: #0051a8; }
      button:disabled { background: #aaa; cursor: not-allowed; }
      .feedback {
        margin-top: 0.75rem;
        font-size: 0.85rem;
        text-align: center;
        color: #22c55e;
        min-height: 1.2em;
      }
      a {
        display: block;
        margin-top: 1.25rem;
        text-align: center;
        color: #0070f3;
        text-decoration: none;
        font-size: 0.9rem;
      }
      a:hover { text-decoration: underline; }
      .pending-section {
        margin-top: 1.5rem;
        border-top: 1px solid #eee;
        padding-top: 1rem;
      }
      .pending-section h2 {
        font-size: 0.85rem;
        color: #888;
        margin: 0 0 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .pending-list {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }
      .pending-item {
        background: #fef9c3;
        border-radius: 6px;
        padding: 0.5rem 0.75rem;
        font-size: 0.85rem;
        color: #555;
      }
      .pending-item .p-phone { font-weight: bold; color: #333; }
      .pending-item .p-time { font-size: 0.75rem; color: #aaa; float: right; }
      .empty { font-size: 0.85rem; color: #aaa; text-align: center; }
      .api-section {
        margin-top: 1.5rem;
        border-top: 1px solid #eee;
        padding-top: 1rem;
      }
      .api-section h2 {
        font-size: 0.85rem;
        color: #888;
        margin: 0 0 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .api-block {
        background: #1e1e1e;
        color: #d4d4d4;
        border-radius: 6px;
        padding: 0.75rem;
        font-size: 0.75rem;
        font-family: monospace;
        white-space: pre;
        overflow-x: auto;
        margin-bottom: 0.75rem;
      }
      .api-block .method { color: #4ec9b0; }
      .api-block .key { color: #9cdcfe; }
      .api-block .val { color: #ce9178; }
      .copy-btn {
        width: auto;
        padding: 0.3rem 0.75rem;
        font-size: 0.75rem;
        background: #444;
        margin-bottom: 0.5rem;
      }
      .copy-btn:hover { background: #222; }
    </style>
  </head>
  <body>
    <div class="card">
      <div class="header">
        <h1>Send SMS</h1>
        <div class="status">
          <div class="dot" id="dot"></div>
          <span id="statusText">Se verifica...</span>
        </div>
      </div>

      <input type="tel" id="phone" placeholder="Numar telefon" />
      <input type="text" id="message" placeholder="Mesaj" />
      <button id="sendBtn" onclick="sendSms()">Trimite</button>
      <div class="feedback" id="feedback"></div>

      <div class="pending-section">
        <h2>In asteptare</h2>
        <div class="pending-list" id="pendingList">
          <div class="empty">Nicio comanda in asteptare</div>
        </div>
      </div>

      <div class="api-section">
        <h2>API</h2>
        <div class="api-block"><span class="method">POST</span> /send-sms
<span class="key">Authorization:</span> <span class="val">Bearer <%= token %></span>
<span class="key">Content-Type:</span> <span class="val">application/json</span>

{
  <span class="key">"phone"</span>:   <span class="val">"0722123456"</span>,
  <span class="key">"message"</span>: <span class="val">"text mesaj"</span>
}</div>
        <button class="copy-btn" onclick="copyToken()">Copiaza token</button>
        <div class="api-block"><span class="method">curl</span> -X POST <%= host %>/send-sms \
  -H <span class="val">"Authorization: Bearer <%= token %>"</span> \
  -H <span class="val">"Content-Type: application/json"</span> \
  -d <span class="val">'{"phone":"0722123456","message":"test"}'</span></div>
      </div>

      <a href="/">← Inapoi</a>
    </div>

    <script>
      const TOKEN = "<%= token %>";
      const dot = document.getElementById("dot");
      const statusText = document.getElementById("statusText");
      let isConnected = false;

      function copyToken() {
        navigator.clipboard.writeText(TOKEN);
      }

      async function checkStatus() {
        try {
          const res = await fetch("/api/ws-status");
          const data = await res.json();
          isConnected = data.connected;
          dot.className = "dot" + (isConnected ? " connected" : "");
          statusText.textContent = isConnected ? "Conectat" : "Deconectat";
        } catch {
          statusText.textContent = "Eroare";
        }
      }

      async function sendSms() {
        const phone = document.getElementById("phone").value.trim();
        const message = document.getElementById("message").value.trim();
        const feedback = document.getElementById("feedback");

        if (!phone || !message) {
          feedback.style.color = "#ef4444";
          feedback.textContent = "Completeaza toate campurile.";
          return;
        }

        const normalized = phone.startsWith("+4") ? phone.slice(2) : phone;
        if (!/^07\d{8}$/.test(normalized)) {
          feedback.style.color = "#ef4444";
          feedback.textContent = "Numar invalid. Format: 07xxxxxxxx sau +407xxxxxxxx.";
          return;
        }

        const res = await fetch("/send-sms", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "Authorization": `Bearer ${TOKEN}`,
          },
          body: JSON.stringify({ phone, message }),
        });

        if (res.ok) {
          feedback.style.color = "#22c55e";
          feedback.textContent = "Trimis cu succes!";
          document.getElementById("phone").value = "";
          document.getElementById("message").value = "";
        } else {
          feedback.style.color = "#ef4444";
          feedback.textContent = "Eroare la trimitere.";
        }
      }

      async function loadPending() {
        const res = await fetch("/api/pending-messages");
        const items = await res.json();
        const list = document.getElementById("pendingList");
        if (!items.length) {
          list.innerHTML = '<div class="empty">Nicio comanda in asteptare</div>';
          return;
        }
        list.innerHTML = items.map(item => `
          <div class="pending-item">
            <span class="p-time">${new Date(item.created_at).toLocaleTimeString()}</span>
            <span class="p-phone">${item.phone}</span><br/>
            ${item.message}
          </div>
        `).join("");
      }

      checkStatus();
      loadPending();
      setInterval(() => { checkStatus(); loadPending(); }, 3000);
    </script>
  </body>
</html>
